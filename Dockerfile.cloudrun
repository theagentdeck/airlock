# ── Diagnose before we fix ─────────────────────────────
# Stage: builder
FROM node:22-slim AS builder

WORKDIR /app

# Step 1: copy scanner package files first
COPY packages/scanner/package.json packages/scanner/package-lock.json* ./packages/scanner/

# Step 2: copy api package files
COPY api/package.json api/package-lock.json* ./api/

# Step 3: install scanner first (so file: path resolves)
RUN cd packages/scanner && npm install

# Step 4: copy scanner source + policies (needed for npm install in api)
COPY packages/scanner/src/ ./packages/scanner/src/
COPY packages/scanner/policies/ ./packages/scanner/policies/

# Step 5: symlink scanner into api/ so the file: dependency resolves
RUN mkdir -p api/packages && cp -r packages/scanner api/packages/scanner

# Step 6: install api deps (now file:packages/scanner resolves)
RUN cd api && npm install

# Step 7: copy api source
COPY api/src/ ./api/src/

# ── Diagnostic before build ───────────────────────────
RUN echo "=== DIAGNOSTIC ===" \
 && echo "PWD=$(pwd)" \
 && echo "--- /app ---" && ls -la \
 && echo "--- /app/packages ---" && ls -la packages/ \
 && echo "--- /app/packages/scanner ---" && ls -la packages/scanner/ \
 && echo "--- /app/api ---" && ls -la api/ \
 && echo "--- /app/api/packages ---" && ls -la api/packages/ \
 && echo "--- /app/api/packages/scanner ---" && ls -la api/packages/scanner/ \
 && echo "--- api/src ---" && ls -la api/src/ \
 && echo "--- find scanner ---" && find . -name "package.json" -maxdepth 4 \
 && echo "=== END DIAGNOSTIC ==="

# Step 8: build
RUN cd api && npm run build

# ── Stage 2: Runtime ──────────────────────────────────
FROM node:22-slim AS runtime

WORKDIR /app

COPY --from=builder /app/api/dist ./api/dist
COPY --from=builder /app/api/package.json ./api/package.json
COPY --from=builder /app/packages/scanner ./packages/scanner
COPY --from=builder /app/api/packages/scanner ./api/packages/scanner

RUN cd api && npm install --omit=dev

ENV NODE_ENV=production
ENV PORT=8080

EXPOSE 8080

HEALTHCHECK --interval=30s --timeout=10s --start-period=10s --retries=3 \
  CMD wget -qO- http://localhost:8080/health || exit 1

WORKDIR /app/api
CMD ["node", "dist/index.js"]
